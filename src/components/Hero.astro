---
import { hero } from "../config/site";
---

<section id="top" class="px-6 pt-20 pb-16 md:pt-28 md:pb-24">
  <div class="max-w-6xl mx-auto">
    <div class="space-y-7 max-w-4xl">
      <p
        class="font-mono text-sm text-terracotta-deep uppercase tracking-wider"
      >
        {hero.eyebrow}
      </p>

      <h1
        class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight text-ink leading-[1.08]"
      >
        Building <span class="text-terracotta-deep">community-powered AI tools</span>
        for the <span class="text-teal-deep">immigrant tech journey</span>.
      </h1>

      <p class="text-lg md:text-xl text-muted max-w-2xl leading-relaxed">
        {hero.subheadline}
      </p>

      <div class="flex flex-wrap gap-3 pt-2">
        <a
          href={hero.primaryCta.href}
          class="px-6 py-3 bg-ink text-cream-soft rounded-full font-medium hover:bg-terracotta-deep transition-colors"
        >
          {hero.primaryCta.label}
        </a>
        <a
          href={hero.secondaryCta.href}
          class="px-6 py-3 border border-ink text-ink rounded-full font-medium hover:bg-ink hover:text-cream-soft transition-colors"
        >
          {hero.secondaryCta.label}
        </a>
        <a
          href={hero.tertiaryCta.href}
          class="px-6 py-3 text-ink rounded-full font-medium hover:text-terracotta-deep transition-colors"
        >
          {hero.tertiaryCta.label} →
        </a>
      </div>

      <div class="flex flex-wrap gap-x-6 gap-y-2 pt-8 text-sm text-muted">
        {
          hero.signals.map((signal) => (
            <span class="flex items-center gap-2">
              {signal.live && (
                <span class="w-2 h-2 rounded-full bg-sage-deep animate-pulse" />
              )}
              {signal.label}
            </span>
          ))
        }
      </div>
    </div>
  </div>
</section>
