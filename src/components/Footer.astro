---
import { footer, socials, contact, emailAvailable, person } from "../config/site";
const year = new Date().getFullYear();
---

<footer class="bg-ink text-cream-soft px-6 py-10 border-t border-cream/10">
  <div
    class="max-w-5xl mx-auto flex flex-col sm:flex-row sm:items-center sm:justify-between gap-5"
  >
    <div>
      <p class="font-bold">{footer.line}</p>
      <p class="text-cream/40 text-xs mt-1">© {year} {person.name}</p>
    </div>

    <div class="flex flex-wrap gap-x-5 gap-y-2 text-sm">
      {
        socials.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("#") ? undefined : "_blank"}
            rel={link.href.startsWith("#") ? undefined : "noopener"}
            class="text-cream/60 hover:text-terracotta transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      {
        emailAvailable && (
          <a
            href={`mailto:${contact.publicEmail}`}
            class="text-cream/60 hover:text-terracotta transition-colors"
          >
            Email
          </a>
        )
      }
    </div>
  </div>
</footer>
