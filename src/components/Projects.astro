---
const projects = [
  {
    name: "cvroast.dev",
    tagline: "AI-powered CV scoring tool",
    description:
      "An open-source AI tool that scores your CV across 6 dimensions against 2026 hiring research. No signup, free, MIT licensed. Built for the Tech Immigrants community.",
    stack: ["Claude API", "Cloudflare Pages", "Cloudflare Functions", "MIT"],
    links: [
      { label: "Visit", href: "https://cvroast.dev" },
      { label: "GitHub", href: "https://github.com/SaharPak/cvroast-dev" },
    ],
    accent: "terracotta",
  },
  {
    name: "TechImmigrants/cv-builder",
    tagline: "Open-source community CV builder",
    description:
      "Scaling cvroast.dev into a contributor-driven open-source product. Recruiting and coordinating a team of developers, designers, and product people from the Tech Immigrants community to build it together.",
    stack: ["TypeScript", "Open Source", "Community-led"],
    links: [
      {
        label: "GitHub",
        href: "https://github.com/TechImmigrants/cv-builder",
      },
    ],
    accent: "teal",
  },
  {
    name: "Tech Immigrants Community",
    tagline: "50K+ followers across platforms",
    description:
      "Founded a tech career community from a single tweet. Grew to 50K+ followers across YouTube and Telegram with 200+ video episodes on career advice, relocation, and tech industry insights. Zero paid promotion.",
    stack: ["Content", "Community", "Podcast"],
    links: [
      { label: "YouTube", href: "https://www.youtube.com/@TechImmigrants" },
      { label: "Telegram", href: "https://t.me/TwitterImmigrant" },
    ],
    accent: "sage",
  },
  {
    name: "Home Cloud",
    tagline: "Self-hosted smart home automation",
    description:
      "Co-built with my husband: 40 sensors, 18+ automations, spot-price energy optimization, baby environment control. Zero cloud subscriptions — fully self-hosted.",
    stack: ["Home Assistant", "Docker", "Ansible", "Zigbee"],
    links: [],
    accent: "purple",
  },
  {
    name: "AI-Powered PM Dashboard",
    tagline: "Custom dashboard for cross-team insights",
    description:
      "Built with Claude Code. Aggregates stakeholder insights from Confluence and Slack across 10+ teams, surfacing blockers and patterns that manual tracking missed.",
    stack: ["Claude Code", "Cursor", "Confluence API", "Slack API"],
    links: [],
    accent: "terracotta",
  },
  {
    name: "KyzDigital C-Level Agents",
    tagline: "Multi-agent AI platform contributor",
    description:
      "Contributing to an AI agent platform with 3 autonomous agents (Ops, Marketing, BD). Using it for Tech Immigrants community operations.",
    stack: ["Multi-agent AI", "ClickUp", "Apollo", "Telegram"],
    links: [],
    accent: "teal",
  },
];

const accentClasses = {
  terracotta: "border-l-terracotta",
  teal: "border-l-teal-deep",
  sage: "border-l-sage-deep",
  purple: "border-l-purple-soft",
};
---

<section id="projects" class="px-6 py-20 border-t border-line bg-cream/30">
  <div class="max-w-5xl mx-auto">
    <p class="font-mono text-sm text-terracotta-deep uppercase tracking-wider mb-4">
      Projects
    </p>

    <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight mb-12">
      What I'm building.
    </h2>

    <div class="space-y-8">
      {
        projects.map((project) => (
          <article
            class={`bg-cream-soft border-l-4 ${accentClasses[project.accent as keyof typeof accentClasses]} p-6 md:p-8 rounded-r-lg shadow-sm hover:shadow-md transition-shadow`}
          >
            <div class="flex flex-wrap items-baseline justify-between gap-2 mb-2">
              <h3 class="text-xl md:text-2xl font-bold text-ink">
                {project.name}
              </h3>
              {project.links.length > 0 && (
                <div class="flex gap-3">
                  {project.links.map((link) => (
                    <a
                      href={link.href}
                      target="_blank"
                      rel="noopener"
                      class="text-sm text-terracotta-deep hover:text-ink transition-colors"
                    >
                      {link.label} →
                    </a>
                  ))}
                </div>
              )}
            </div>
            <p class="text-muted text-sm font-medium mb-3 italic">
              {project.tagline}
            </p>
            <p class="text-body leading-relaxed mb-4">{project.description}</p>
            <div class="flex flex-wrap gap-2">
              {project.stack.map((tech) => (
                <span class="text-xs font-mono text-muted bg-cream px-2 py-1 rounded">
                  {tech}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
