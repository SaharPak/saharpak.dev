---
import { projectCategories, type ProjectStatus } from "../config/site";

const statusStyles: Record<ProjectStatus, string> = {
  Live: "bg-sage-deep/15 text-sage-deep border-sage-deep/30",
  "Open Source": "bg-teal-deep/12 text-teal-deep border-teal-deep/30",
  Pilot: "bg-terracotta/15 text-terracotta-deep border-terracotta/40",
  Demo: "bg-purple-soft/15 text-purple-soft border-purple-soft/40",
  "Internal Tool": "bg-cream text-muted border-line",
  Experiment: "bg-cream text-muted border-line",
  "Coming Soon": "bg-cream text-muted border-line",
  Idea: "bg-cream text-muted border-line",
};
---

<section id="projects" class="px-6 py-20 border-t border-line bg-cream/30">
  <div class="max-w-6xl mx-auto">
    <p
      class="font-mono text-sm text-terracotta-deep uppercase tracking-wider mb-4"
    >
      Projects & Products
    </p>

    <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight mb-3">
      What I'm building.
    </h2>
    <p class="text-lg text-muted max-w-2xl mb-12">
      Grouped by where they fit in the ecosystem. Status labels are honest:
      some are live, many are early experiments.
    </p>

    <div class="space-y-16">
      {
        projectCategories.map((category) => (
          <div>
            <div class="mb-6">
              <h3 class="text-xl md:text-2xl font-bold text-ink">
                {category.title}
              </h3>
              <p class="text-muted mt-1">{category.blurb}</p>
            </div>

            <div class="grid md:grid-cols-2 gap-5">
              {category.projects.map((project) => (
                <article class="flex flex-col bg-cream-soft border border-line rounded-xl p-6 hover:shadow-md hover:border-terracotta/40 transition-all">
                  <div class="flex items-start justify-between gap-3 mb-2">
                    <h4 class="text-lg font-bold text-ink">{project.name}</h4>
                    <span
                      class={`shrink-0 text-xs font-mono font-medium px-2.5 py-1 rounded-full border ${statusStyles[project.status]}`}
                    >
                      {project.status}
                    </span>
                  </div>

                  <p class="text-body leading-relaxed">{project.description}</p>

                  <p class="text-sm text-muted italic mt-3">
                    Why: {project.why}
                  </p>

                  {(project.links?.length || project.cta) && (
                    <div class="flex flex-wrap gap-4 mt-4 pt-4 border-t border-line">
                      {project.links?.map((link) => (
                        <a
                          href={link.href}
                          target="_blank"
                          rel="noopener"
                          class="text-sm font-medium text-terracotta-deep hover:text-ink transition-colors"
                        >
                          {link.label} →
                        </a>
                      ))}
                      {project.cta && (
                        <a
                          href={project.cta.href}
                          class="text-sm font-medium text-teal-deep hover:text-ink transition-colors"
                        >
                          {project.cta.label} →
                        </a>
                      )}
                    </div>
                  )}
                </article>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
