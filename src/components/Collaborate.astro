---
import { collaboration } from "../config/site";
---

<section id="collaborate" class="px-6 py-20 border-t border-line">
  <div class="max-w-6xl mx-auto">
    <p
      class="font-mono text-sm text-terracotta-deep uppercase tracking-wider mb-4"
    >
      Collaborate
    </p>

    <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight">
      {collaboration.heading}
    </h2>
    <p class="text-lg text-muted max-w-2xl mt-4">{collaboration.intro}</p>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3 mt-10">
      {
        collaboration.options.map((option) => (
          <li class="flex items-center gap-3 p-4 bg-cream border border-line rounded-xl text-body">
            <span class="text-terracotta-deep" aria-hidden="true">
              ▸
            </span>
            {option}
          </li>
        ))
      }
    </ul>

    <div class="mt-10 flex flex-wrap items-center gap-6">
      <a
        href={collaboration.cta.href}
        class="px-6 py-3 bg-ink text-cream-soft rounded-full font-medium hover:bg-terracotta-deep transition-colors"
      >
        {collaboration.cta.label}
      </a>
      <p class="text-sm text-sage-deep font-medium max-w-md">
        {collaboration.trustNote}
      </p>
    </div>
  </div>
</section>
