---
import { currentFocus } from "../config/site";
---

<section id="focus" class="px-6 py-20 border-t border-line">
  <div class="max-w-6xl mx-auto">
    <p
      class="font-mono text-sm text-terracotta-deep uppercase tracking-wider mb-4"
    >
      Current Focus
    </p>

    <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight">
      {currentFocus.heading}
    </h2>
    <p class="text-lg text-muted max-w-2xl mt-4">{currentFocus.intro}</p>

    <ul class="grid sm:grid-cols-2 gap-4 mt-10">
      {
        currentFocus.items.map((item, i) => (
          <li class="flex gap-4 p-5 bg-cream border border-line rounded-xl">
            <span class="font-mono text-sm text-terracotta-deep font-semibold">
              {String(i + 1).padStart(2, "0")}
            </span>
            <span class="text-body leading-relaxed">{item}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
