---
import { contact } from "../config/site";
---

<section
  id="contact"
  class="px-6 py-20 border-t border-line bg-ink text-cream-soft"
>
  <div class="max-w-6xl mx-auto">
    <p
      class="font-mono text-sm text-terracotta uppercase tracking-wider mb-4"
    >
      Contact
    </p>

    <h2 class="text-3xl md:text-5xl font-bold leading-tight mb-6 max-w-3xl">
      {contact.heading}
    </h2>

    <p class="text-lg text-cream/80 max-w-2xl leading-relaxed mb-8">
      {contact.intro}
    </p>

    {
      contact.emailPublished && contact.email ? (
        <a
          href={`mailto:${contact.email}`}
          class="inline-flex items-center gap-2 px-6 py-3 mb-12 rounded-full bg-cream-soft text-ink font-medium hover:bg-terracotta hover:text-cream-soft transition-colors"
        >
          {contact.email} →
        </a>
      ) : (
        <a
          href={contact.primaryAction.href}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-6 py-3 mb-12 rounded-full bg-cream-soft text-ink font-medium hover:bg-terracotta hover:text-cream-soft transition-colors"
        >
          {contact.primaryAction.label} →
        </a>
      )
    }

    <div class="grid sm:grid-cols-2 gap-4">
      {
        contact.socials.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("#") ? undefined : "_blank"}
            rel={link.href.startsWith("#") ? undefined : "noopener"}
            class="group flex items-center justify-between p-5 border border-cream/20 rounded-xl hover:border-terracotta hover:bg-cream/5 transition-all"
          >
            <div>
              <p class="font-bold">{link.label}</p>
              <p class="text-sm text-cream/60 font-mono">{link.handle}</p>
            </div>
            <span class="text-cream/40 group-hover:text-terracotta group-hover:translate-x-1 transition-all">
              →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
