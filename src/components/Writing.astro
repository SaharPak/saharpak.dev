<section id="writing" class="px-6 py-20 border-t border-line">
  <div class="max-w-5xl mx-auto">
    <div class="flex items-baseline justify-between mb-12 flex-wrap gap-4">
      <div>
        <p class="font-mono text-sm text-terracotta-deep uppercase tracking-wider mb-4">
          Writing
        </p>
        <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight">
          Recent posts.
        </h2>
      </div>
      <a
        href="https://medium.com/@saharlead"
        target="_blank"
        rel="noopener"
        class="text-sm text-terracotta-deep hover:text-ink transition-colors"
      >
        All posts on Medium →
      </a>
    </div>

    <div class="space-y-6">
      {
        posts.map((post) => (
          <a
            href={post.href}
            target="_blank"
            rel="noopener"
            class="block group p-6 border border-line rounded-lg hover:border-terracotta hover:bg-cream/50 transition-all"
          >
            <div class="flex items-center gap-3 text-xs font-mono text-muted mb-2">
              <span>{post.date}</span>
              <span>·</span>
              <span class="text-terracotta-deep">{post.tag}</span>
            </div>
            <h3 class="text-xl font-bold text-ink group-hover:text-terracotta-deep transition-colors mb-2">
              {post.title}
            </h3>
            <p class="text-body leading-relaxed">{post.description}</p>
          </a>
        ))
      }
    </div>
  </div>
</section>
