---
import { about } from "../config/site";
---

<section id="about" class="px-6 py-20 border-t border-line">
  <div class="max-w-6xl mx-auto">
    <p
      class="font-mono text-sm text-terracotta-deep uppercase tracking-wider mb-4"
    >
      About
    </p>

    <div class="grid md:grid-cols-5 gap-12 items-start">
      <div class="md:col-span-3 space-y-6">
        <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight">
          {about.heading}
        </h2>

        <div class="space-y-4 text-lg text-body leading-relaxed">
          {about.paragraphs.map((p) => <p>{p}</p>)}
        </div>
      </div>

      <div class="md:col-span-2">
        <p class="font-mono text-xs text-muted uppercase tracking-wider mb-3">
          Where I focus
        </p>
        <div class="flex flex-wrap gap-2">
          {
            about.interests.map((item) => (
              <span class="px-3 py-1 bg-cream border border-line rounded-full text-sm text-ink">
                {item}
              </span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
