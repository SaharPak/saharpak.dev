---
import { nav } from "../config/site";
---

<nav class="sticky top-0 z-50 backdrop-blur-md bg-cream-soft/80 border-b border-line">
  <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
    <a
      href="#top"
      class="font-bold text-lg tracking-tight text-ink hover:text-terracotta-deep transition-colors"
    >
      saharpak<span class="text-terracotta">.dev</span>
    </a>

    <div class="flex items-center gap-6">
      <div class="hidden sm:flex items-center gap-6">
        {
          nav.links.map((link) => (
            <a
              href={link.href}
              class="text-sm text-muted hover:text-ink transition-colors"
            >
              {link.label}
            </a>
          ))
        }
      </div>
      <a
        href="#contact"
        class="text-sm font-medium px-4 py-2 rounded-full bg-ink text-cream-soft hover:bg-terracotta-deep transition-colors"
      >
        Let's talk
      </a>
    </div>
  </div>
</nav>
