---
import { community } from "../config/site";
---

<section id="community" class="px-6 py-14 border-t border-line">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3 mb-8">
      <h2 class="text-2xl md:text-3xl font-bold text-ink">{community.title}</h2>
      <p class="text-muted">{community.line}</p>
    </div>

    <div class="grid grid-cols-3 gap-4">
      {
        community.stats.map((stat) => (
          <div class="text-center sm:text-left p-5 bg-cream border border-line rounded-2xl">
            <p class="text-3xl md:text-4xl font-extrabold text-teal-deep tracking-tight">
              {stat.value}
            </p>
            <p class="text-xs sm:text-sm text-muted mt-1 leading-snug">
              {stat.label}
            </p>
          </div>
        ))
      }
    </div>

    <p class="text-xs text-muted mt-4">{community.privacyNote}</p>
  </div>
</section>
