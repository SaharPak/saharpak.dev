---
import { communityIntelligence as ci } from "../config/site";
---

<section id="intelligence" class="px-6 py-20 border-t border-line">
  <div class="max-w-6xl mx-auto">
    <p
      class="font-mono text-sm text-terracotta-deep uppercase tracking-wider mb-4"
    >
      Community Intelligence
    </p>

    <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight max-w-3xl">
      {ci.heading}
    </h2>

    <p class="text-lg text-body leading-relaxed max-w-3xl mt-6">
      {ci.intro}
    </p>

    <div class="grid grid-cols-2 lg:grid-cols-3 gap-4 mt-10">
      {
        ci.stats.map((stat) => (
          <div class="p-6 bg-cream border border-line rounded-xl">
            <p class="text-3xl md:text-4xl font-extrabold text-teal-deep tracking-tight">
              {stat.value}
            </p>
            <p class="text-sm text-muted mt-1 leading-snug">{stat.label}</p>
          </div>
        ))
      }
    </div>

    <div
      class="mt-6 p-5 rounded-xl bg-terracotta/10 border border-terracotta/30"
    >
      <p class="text-ink font-semibold">
        <span class="text-terracotta-deep">↗</span>
        {ci.highlight}
      </p>
    </div>

    <div class="mt-8 flex flex-wrap items-center gap-4">
      {
        ci.report.available ? (
          <a
            href={ci.report.href}
            class="px-5 py-2.5 rounded-full bg-ink text-cream-soft font-medium hover:bg-terracotta-deep transition-colors"
          >
            {ci.report.label}
          </a>
        ) : (
          <span class="px-5 py-2.5 rounded-full border border-line text-muted font-medium cursor-default">
            {ci.report.label}
          </span>
        )
      }
      <p class="text-sm text-muted max-w-md">{ci.privacyNote}</p>
    </div>
  </div>
</section>
