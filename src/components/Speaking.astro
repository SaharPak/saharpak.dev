---
import { speaking } from "../config/site";
---

<section id="speaking" class="px-6 py-20 border-t border-line bg-cream/30">
  <div class="max-w-6xl mx-auto">
    <p
      class="font-mono text-sm text-terracotta-deep uppercase tracking-wider mb-4"
    >
      Speaking & Events
    </p>

    <h2 class="text-3xl md:text-4xl font-bold text-ink leading-tight">
      {speaking.heading}
    </h2>
    <p class="text-lg text-muted max-w-2xl mt-4">{speaking.intro}</p>

    <div class="grid sm:grid-cols-2 gap-4 mt-10">
      {
        speaking.items.map((item) => (
          <a
            href={item.href}
            target={item.href.startsWith("#") ? undefined : "_blank"}
            rel={item.href.startsWith("#") ? undefined : "noopener"}
            class="group flex items-start justify-between gap-4 p-6 bg-cream-soft border border-line rounded-xl hover:border-terracotta hover:shadow-sm transition-all"
          >
            <div>
              <p class="font-bold text-ink group-hover:text-terracotta-deep transition-colors">
                {item.title}
              </p>
              <p class="text-sm text-muted mt-1 leading-relaxed">
                {item.detail}
              </p>
            </div>
            <span class="text-muted group-hover:text-terracotta group-hover:translate-x-1 transition-all">
              →
            </span>
          </a>
        ))
      }
    </div>
  </div>
</section>
